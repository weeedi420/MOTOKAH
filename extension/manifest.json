{
  "manifest_version": 3,
  "name": "Motokah Scraper",
  "version": "2.0",
  "description": "Scrape car listings from Jiji East Africa + Nigeria",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://jiji.co.tz/*", "*://www.jiji.co.tz/*",
    "*://jiji.co.ke/*", "*://www.jiji.co.ke/*",
    "*://jiji.ug/*", "*://www.jiji.ug/*",
    "*://jiji.rw/*", "*://www.jiji.rw/*",
    "*://jiji.bi/*", "*://www.jiji.bi/*",
    "*://jiji.com.et/*", "*://www.jiji.com.et/*",
    "*://jiji.ng/*", "*://www.jiji.ng/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://jiji.co.tz/*", "*://www.jiji.co.tz/*",
        "*://jiji.co.ke/*", "*://www.jiji.co.ke/*",
        "*://jiji.ug/*", "*://www.jiji.ug/*",
        "*://jiji.rw/*", "*://www.jiji.rw/*",
        "*://jiji.bi/*", "*://www.jiji.bi/*",
        "*://jiji.com.et/*", "*://www.jiji.com.et/*",
        "*://jiji.ng/*", "*://www.jiji.ng/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
