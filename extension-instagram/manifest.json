{
  "manifest_version": 3,
  "name": "Motokah Instagram Scraper",
  "version": "1.0",
  "description": "Scrape car listings from Instagram — photos, captions, usernames & contact numbers",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "*://www.instagram.com/*",
    "*://instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*", "*://instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
